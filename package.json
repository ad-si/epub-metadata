{
  "name": "epub-metadata",
  "version": "0.3.0",
  "description": "Reads metadata from epub files",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "epub-metadata": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "source"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build",
    "test": "npm run build && node --test 'tests/**/*.test.js'",
    "typecheck": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adius/epub-metadata.git"
  },
  "keywords": [
    "epub",
    "metadata",
    "ebook"
  ],
  "author": "Adrian Sieber",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/adius/epub-metadata/issues"
  },
  "homepage": "https://github.com/adius/epub-metadata#readme",
  "dependencies": {
    "fast-xml-parser": "^4.5.0",
    "jszip": "^3.10.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.4.0"
  }
}
